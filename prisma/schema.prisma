generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageRole {
  system
  user
  assistant
}

enum OutputFormat {
  markdown
  json
  template
}

enum UserRole {
  USER
  TEAM_LEAD
  ADMIN
}

enum AgentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AgentScope {
  TEAM
  GLOBAL
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  role         UserRole      @default(USER)
  teamId       String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  chatSessions ChatSession[]
  messages     Message[]
  savedPrompts SavedPrompt[]
  tokenUsages  TokenUsage[]
  team         Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([role])
  @@index([teamId])
}

model Team {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  agents    AgentConfig[]
  members   User[]

  @@index([slug])
}

model ChatSession {
  id        String    @id @default(cuid())
  userId    String
  title     String    @default("New Chat")
  summary   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  shares    SharedChat[]

  @@index([userId, updatedAt])
  @@index([userId])
}

model Message {
  id            String      @id @default(cuid())
  sessionId     String
  userId        String
  role          MessageRole
  content       String
  imageUrls     Json?
  agentConfigId String?
  editedFromId  String?
  regenOfId     String?
  createdAt     DateTime    @default(now())
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentConfig   AgentConfig? @relation(fields: [agentConfigId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
  @@index([sessionId])
  @@index([userId, createdAt])
}

model AgentConfig {
  id           String       @id @default(cuid())
  slug         String       @unique
  name         String
  description  String?
  systemPrompt String
  inputSchema  Json?
  outputFormat OutputFormat @default(markdown)
  outputSchema Json?
  temperature  Float        @default(0.4)
  maxTokens    Int          @default(800)
  isEnabled    Boolean      @default(true)
  status       AgentStatus  @default(PUBLISHED)
  scope        AgentScope   @default(GLOBAL)
  teamId       String?
  team         Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  messages     Message[]

  @@index([teamId])
  @@index([status])
  @@index([scope])
}

model SavedPrompt {
  id         String   @id @default(cuid())
  userId     String
  title      String
  promptText String
  outputText String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TokenUsage {
  id           String   @id @default(cuid())
  userId       String
  sessionId    String?
  model        String
  promptTokens Int      @default(0)
  completionTokens Int  @default(0)
  totalTokens  Int      @default(0)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SharedChat {
  id         String      @id @default(cuid())
  sessionId  String
  token      String      @unique
  createdAt  DateTime    @default(now())
  expiresAt  DateTime?
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}
