generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageRole {
  system
  user
  assistant
}

enum OutputFormat {
  markdown
  json
  template
}

enum UserRole {
  USER
  TEAM_LEAD
  ADMIN
}

// Workspace-scoped role (auth); complements legacy User.role.
enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum AgentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AgentScope {
  TEAM
  GLOBAL
}

enum MessageDeliveryStatus {
  PENDING
  STREAMING
  FAILED
  COMPLETED
  CANCELLED
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String? // bcrypt; null until password set
  role         UserRole      @default(USER)
  teamId       String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  chatSessions ChatSession[]
  messages     Message[]
  savedPrompts SavedPrompt[]
  tokenUsages  TokenUsage[]
  team         Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  workspaceMembers WorkspaceMember[]
  passwordResetTokens PasswordResetToken[]
  sentWorkspaceInvitations WorkspaceInvitation[] @relation("WorkspaceInvitationInvitedBy")

  @@index([role])
  @@index([teamId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@index([usedAt])
}

model Workspace {
  id        String            @id @default(cuid())
  name      String
  slug      String            @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  members   WorkspaceMember[]
  invitations WorkspaceInvitation[]
  teams     Team[]
  agents    AgentConfig[]
  knowledgeItems KnowledgeItem[]

  @@index([slug])
}

model WorkspaceInvitation {
  id          String        @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole @default(MEMBER)
  teamId      String?
  tokenHash   String        @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  invitedById String
  createdAt   DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team        Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  invitedBy   User          @relation("WorkspaceInvitationInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([email])
  @@index([expiresAt])
  @@index([acceptedAt])
  @@index([revokedAt])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  teamId      String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  team        Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
  @@index([isActive])
  @@index([teamId])
}

model Team {
  id        String        @id @default(cuid())
  workspaceId String?
  name      String
  slug      String        @unique
  isArchived Boolean      @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  workspace Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  agents    AgentConfig[]
  members   User[]
  invitations WorkspaceInvitation[]
  workspaceMembers WorkspaceMember[]
  knowledgeItems KnowledgeItem[]

  @@index([slug])
  @@index([workspaceId])
  @@index([isArchived])
}

model ChatSession {
  id        String    @id @default(cuid())
  userId    String
  title     String    @default("New Chat")
  summary   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  shares    SharedChat[]

  @@index([userId, updatedAt])
  @@index([userId])
}

model Message {
  id                        String                @id @default(cuid())
  sessionId                 String
  userId                    String
  role                      MessageRole
  content                   String
  imageUrls                 Json?
  agentConfigId             String?
  editedFromId              String?
  regenOfId                 String?
  turnId                    String?
  deliveryStatus            MessageDeliveryStatus @default(COMPLETED)
  retryOfAssistantMessageId String?
  attemptIndex              Int?
  errorCode                 String?
  errorMessage              String?
  provider                  String?
  model                     String?
  startedAt                 DateTime?
  completedAt               DateTime?
  failedAt                  DateTime?
  createdAt                 DateTime              @default(now())
  session                   ChatSession           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user                      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentConfig               AgentConfig?          @relation(fields: [agentConfigId], references: [id], onDelete: SetNull)
  retryOfAssistantMessage   Message?              @relation("MessageRetryLineage", fields: [retryOfAssistantMessageId], references: [id], onDelete: SetNull)
  retryAttempts             Message[]             @relation("MessageRetryLineage")

  @@index([sessionId, createdAt])
  @@index([sessionId])
  @@index([userId, createdAt])
  @@index([retryOfAssistantMessageId])
  @@index([sessionId, turnId, createdAt])
  @@index([sessionId, turnId, attemptIndex])
}

model AgentConfig {
  id           String       @id @default(cuid())
  workspaceId  String
  slug         String       @unique
  name         String
  description  String?
  systemPrompt String
  inputSchema  Json?
  outputFormat OutputFormat @default(markdown)
  outputSchema Json?
  temperature  Float        @default(0.4)
  maxTokens    Int          @default(800)
  isEnabled    Boolean      @default(true)
  status       AgentStatus  @default(PUBLISHED)
  scope        AgentScope   @default(GLOBAL)
  teamId       String?
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team         Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  messages     Message[]
  knowledgeLinks AgentKnowledge[]

  @@index([workspaceId])
  @@index([teamId])
  @@index([status])
  @@index([scope])
}

model KnowledgeItem {
  id          String   @id @default(cuid())
  workspaceId String
  teamId      String?
  title       String
  sourceType  String
  content     String?
  fileRef     Json?
  summary     String   @default("")
  tags        Json?
  priority    Int      @default(3)
  appliesTo   String   @default("all")
  isActive    Boolean  @default(true)
  ownerNote   String   @default("")
  lastReviewedAt DateTime?
  processingStatus String @default("ready")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team        Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  agentLinks  AgentKnowledge[]

  @@index([workspaceId])
  @@index([teamId])
  @@index([isActive])
}

model AgentKnowledge {
  id           String       @id @default(cuid())
  agentId      String
  knowledgeId  String
  legacyItemId String?
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())
  agent        AgentConfig  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  knowledge    KnowledgeItem @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)

  @@unique([agentId, knowledgeId])
  @@index([agentId])
  @@index([knowledgeId])
  @@index([legacyItemId])
}

model SavedPrompt {
  id         String   @id @default(cuid())
  userId     String
  title      String
  promptText String
  outputText String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TokenUsage {
  id           String   @id @default(cuid())
  userId       String
  sessionId    String?
  messageId    String?
  model        String
  registryModelId String?
  provider     String?
  promptTokens Int      @default(0)
  completionTokens Int  @default(0)
  totalTokens  Int      @default(0)
  cachedInputTokens Int?
  exactUsage   Boolean  @default(false)
  estimationMethod String?
  pricingSnapshot Json?
  inputCost    Float?
  outputCost   Float?
  totalCost    Float?
  currency     String?
  serviceTier  String?
  routerMode   String?
  routerReasonCodes Json?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([messageId])
}

model SharedChat {
  id         String      @id @default(cuid())
  sessionId  String
  token      String      @unique
  createdAt  DateTime    @default(now())
  expiresAt  DateTime?
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}
