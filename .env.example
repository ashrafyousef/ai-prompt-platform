DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_prompt_platform?schema=public"
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
OPENAI_API_KEY=""

# --- Vercel production ---
# Set these in Vercel → Project → Settings → Environment Variables (Production).
# NEXTAUTH_URL must match your deployment URL exactly, e.g.:
#   https://ai-prompt-platform-sepia.vercel.app
# NEXTAUTH_SECRET: run `openssl rand -base64 32` and paste the result.
# DATABASE_URL: your hosted Postgres (Neon, Supabase, Vercel Postgres, etc.).
# After changing env vars, redeploy.
